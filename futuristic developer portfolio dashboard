  <style>
    * { box-sizing: border-box; }
    body {
      font-family: 'JetBrains Mono', monospace;
      background: #050510;
      color: #e0e0ff;
      overflow-x: hidden;
    }
    .font-orbitron { font-family: 'Orbitron', sans-serif; }

    /* Neon border glow utilities */
    .border-neon-cyan  { border-color: #00f5ff; box-shadow: 0 0 8px #00f5ff44, inset 0 0 8px #00f5ff11; }
    .border-neon-purple{ border-color: #bf00ff; box-shadow: 0 0 8px #bf00ff44, inset 0 0 8px #bf00ff11; }
    .border-neon-green { border-color: #39ff14; box-shadow: 0 0 8px #39ff1444, inset 0 0 8px #39ff1411; }
    .border-neon-pink  { border-color: #ff006e; box-shadow: 0 0 8px #ff006e44, inset 0 0 8px #ff006e11; }

    .text-neon-cyan   { color: #00f5ff; }
    .text-neon-purple { color: #bf00ff; }
    .text-neon-green  { color: #39ff14; }
    .text-neon-pink   { color: #ff006e; }
    .text-neon-yellow { color: #ffe600; }

    .glow-cyan   { text-shadow: 0 0 12px #00f5ff, 0 0 24px #00f5ff88; }
    .glow-purple { text-shadow: 0 0 12px #bf00ff, 0 0 24px #bf00ff88; }
    .glow-green  { text-shadow: 0 0 12px #39ff14, 0 0 24px #39ff1488; }
    .glow-pink   { text-shadow: 0 0 12px #ff006e, 0 0 24px #ff006e88; }

    .card {
      background: linear-gradient(135deg, #0a0a1a 0%, #0f0f2a 100%);
      border: 1px solid;
      border-radius: 12px;
      padding: 1.25rem;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover { transform: translateY(-4px); }
    .card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, currentColor, transparent);
      opacity: 0.6;
    }

    /* Contribution graph cells */
    .contrib-cell {
      width: 12px; height: 12px;
      border-radius: 2px;
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .contrib-cell:hover { transform: scale(1.4); z-index: 10; position: relative; }

    /* Skill bar */
    .skill-bar-track {
      background: #1a1a4a;
      border-radius: 999px;
      height: 8px;
      overflow: hidden;
    }
    .skill-bar-fill {
      height: 100%;
      border-radius: 999px;
      transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Scanline overlay */
    .scanline {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, #00f5ff33, transparent);
      pointer-events: none;
      z-index: 9999;
      animation: scan 6s linear infinite;
    }

    /* Grid background */
    .grid-bg {
      background-image:
        linear-gradient(rgba(0,245,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,245,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    /* Blinking cursor */
    .cursor::after {
      content: '|';
      animation: blink 1s step-end infinite;
      color: #00f5ff;
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    /* Repo card hover */
    .repo-card {
      transition: all 0.3s ease;
      cursor: pointer;
    }
    .repo-card:hover {
      transform: translateY(-6px) scale(1.02);
    }

    /* Status dot pulse */
    .status-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #39ff14;
      box-shadow: 0 0 6px #39ff14, 0 0 12px #39ff14;
      animation: pulse 2s ease-in-out infinite;
    }

    /* Metric counter */
    .metric-value {
      font-family: 'Orbitron', sans-serif;
      font-size: 2rem;
      font-weight: 700;
      line-height: 1;
    }

    /* Activity feed item */
    .activity-item {
      border-left: 2px solid;
      padding-left: 0.75rem;
      margin-bottom: 0.75rem;
      animation: fadeInLeft 0.5s ease forwards;
    }
    @keyframes fadeInLeft {
      from { opacity: 0; transform: translateX(-10px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: #0a0a1a; }
    ::-webkit-scrollbar-thumb { background: #00f5ff44; border-radius: 2px; }
  </style>
</head>
