  setInterval(updateClock, 1000);
  document.getElementById('footer-year').textContent = new Date().getFullYear();

  // ─── COUNTER ANIMATION ───────────────────────────────────────────────────────
  function animateCounter(el, target, duration = 1800) {
    let start = 0;
    const step = target / (duration / 16);
    const timer = setInterval(() => {
      start = Math.min(start + step, target);
      el.textContent = Math.floor(start).toLocaleString();
      if (start >= target) clearInterval(timer);
    }, 16);
  }

  window.addEventListener('load', () => {
    animateCounter(document.getElementById('commit-count'), 2847);
    animateCounter(document.getElementById('repo-count'),   34);
    animateCounter(document.getElementById('star-count'),   2654);
    animateCounter(document.getElementById('streak'),       73);
    animateCounter(document.getElementById('prs'),          189);
    animateCounter(document.getElementById('issues'),       412);
    animateCounter(document.getElementById('followers'),    1203);
  });

  // ─── CONTRIBUTION GRAPH ──────────────────────────────────────────────────────
  function buildContribGraph() {
    const container = document.getElementById('contrib-graph');
    const totalWeeks = 52;
    const totalDays  = totalWeeks * 7;
    let totalContribs = 0;

    const levels = [
      { bg: '#1a1a4a', shadow: 'none' },
      { bg: '#003d4d', shadow: 'none' },
      { bg: '#006680', shadow: '0 0 3px #006680' },
      { bg: '#00a8cc', shadow: '0 0 5px #00a8cc' },
      { bg: '#00f5ff', shadow: '0 0 8px #00f5ff, 0 0 16px #00f5ff44' },
    ];

    for (let i = 0; i < totalDays; i++) {
      const rand = Math.random();
      let level;
      if      (rand < 0.35) level = 0;
      else if (rand < 0.55) level = 1;
      else if (rand < 0.72) level = 2;
      else if (rand < 0.87) level = 3;
      else                  level = 4;

      const contribs = level === 0 ? 0 : Math.floor(Math.random() * 12 * level) + 1;
      totalContribs += contribs;

      const cell = document.createElement('div');
      cell.className = 'contrib-cell';
      cell.style.background  = levels[level].bg;
      cell.style.boxShadow   = levels[level].shadow;
      cell.title = `${contribs} contribution${contribs !== 1 ? 's' : ''}`;
      container.appendChild(cell);
    }

    document.getElementById('graph-summary').textContent =
      `${totalContribs.toLocaleString()} contributions in the last year · Longest streak: 73 days`;
  }
  buildContribGraph();

  // ─── REPO CARDS ──────────────────────────────────────────────────────────────
  function buildRepos() {
    const grid = document.getElementById('repo-grid');
    REPOS.forEach((repo, i) => {
      const card = document.createElement('div');
      card.className = `card repo-card ${repo.borderClass}`;
      card.style.color = repo.color;
      card.style.animationDelay = `${i * 0.1}s`;
      card.innerHTML = `
        <div class="flex items-start justify-between mb-2">
          <div>
            <p class="font-orbitron text-xs font-bold" style="color:${repo.color}; text-shadow:0 0 8px ${repo.color}88">${repo.name}</p>
            <p class="text-xs text-gray-500 mt-0.5">Updated ${repo.updated}</p>
          </div>
          <span class="text-lg">📦</span>
        </div>
        <p class="text-xs text-gray-400 mb-3 leading-relaxed">${repo.desc}</p>
        <div class="flex flex-wrap gap-1 mb-3">
          ${repo.topics.map(t => `<span class="px-1.5 py-0.5 rounded text-xs" style="border:1px solid ${repo.color}44; color:${repo.color}; background:${repo.color}11">${t}</span>`).join('')}
        </div>
        <div class="flex items-center gap-4 text-xs text-gray-500">
          <span class="flex items-center gap-1">
            <span style="width:8px;height:8px;border-radius:50%;background:${repo.langColor};display:inline-block"></span>
            ${repo.lang}
          </span>
          <span>⭐ ${repo.stars.toLocaleString()}</span>
          <span>🍴 ${repo.forks}</span>
          <span>🐛 ${repo.issues}</span>
        </div>
      `;
      grid.appendChild(card);
    });
  }
  buildRepos();

  // ─── ACTIVITY FEED ───────────────────────────────────────────────────────────
  function buildActivity() {
    const feed = document.getElementById('activity-feed');
    ACTIVITY_EVENTS.forEach((ev, i) => {
      const item = document.createElement('div');
      item.className = 'activity-item';
      item.style.borderColor = ev.color;
      item.style.animationDelay = `${i * 0.08}s`;
      item.style.opacity = '0';
      item.innerHTML = `
        <div class="flex items-start gap-2">
          <span class="text-sm flex-shrink-0">${ev.icon}</span>
          <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-300 leading-relaxed">${ev.text}</p>
            <p class="text-xs mt-0.5" style="color:${ev.color}88">${ev.time}</p>
          </div>
        </div>
      `;
      feed.appendChild(item);
      // Staggered reveal
      setTimeout(() => { item.style.opacity = '1'; }, i * 80);
    });
  }
  buildActivity();

  // Simulate new activity every 8s
  const NEW_EVENTS = [
    { icon: '⬆️', text: 'Pushed 2 commits to <b>luxe-ui-kit</b>',          color: '#00f5ff' },
    { icon: '⭐', text: '<b>codebase-memory-mcp</b> received a new star',   color: '#ffe600' },
    { icon: '🔀', text: 'Opened PR #53 in <b>ai-code-reviewer</b>',         color: '#bf00ff' },
    { icon: '🐛', text: 'Closed issue #9 in <b>codebase-memory-mcp</b>',   color: '#39ff14' },
  ];
  let newEventIdx = 0;
  setInterval(() => {
    const feed = document.getElementById('activity-feed');
    const ev   = NEW_EVENTS[newEventIdx % NEW_EVENTS.length];
    newEventIdx++;
    const item = document.createElement('div');
    item.className = 'activity-item';
    item.style.borderColor = ev.color;
    item.style.opacity = '0';
    item.innerHTML = `
      <div class="flex items-start gap-2">
        <span class="text-sm flex-shrink-0">${ev.icon}</span>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-gray-300 leading-relaxed">${ev.text}</p>
          <p class="text-xs mt-0.5" style="color:${ev.color}88">just now</p>
        </div>
      </div>
    `;
    feed.insertBefore(item, feed.firstChild);
    setTimeout(() => { item.style.opacity = '1'; }, 50);
    // Keep feed trimmed
    while (feed.children.length > 12) feed.removeChild(feed.lastChild);
  }, 8000);

  // ─── SKILLS ──────────────────────────────────────────────────────────────────
  function buildSkills() {
    const list = document.getElementById('skills-list');
    SKILLS.forEach((skill, i) => {
      const row = document.createElement('div');
      row.innerHTML = `
        <div class="flex justify-between text-xs mb-1">
          <span class="text-gray-300">${skill.name}</span>
          <span style="color:${skill.color}">${skill.pct}%</span>
        </div>
        <div class="skill-bar-track">
          <div class="skill-bar-fill" data-pct="${skill.pct}"
               style="width:0%; background:linear-gradient(90deg,${skill.color}88,${skill.color}); box-shadow:0 0 6px ${skill.color}88"></div>
        </div>
      `;
      list.appendChild(row);
    });

    // Animate bars on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll('.skill-bar-fill').forEach((bar, i) => {
            setTimeout(() => {
              bar.style.width = bar.dataset.pct + '%';
            }, i * 150);
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(list);
  }
  buildSkills();

  function buildLangs() {
    const chart = document.getElementById('lang-chart');
    // Stacked bar
    const stackBar = document.createElement('div');
    stackBar.className = 'flex rounded-full overflow-hidden h-4 mb-4';
    stackBar.style.boxShadow = '0 0 10px #00000088';
    LANGS.forEach(l => {
      const seg = document.createElement('div');
      seg.style.width = l.pct + '%';
      seg.style.background = l.color;
      seg.style.transition = 'width 1.5s ease';
      seg.title = `${l.name}: ${l.pct}%`;
      stackBar.appendChild(seg);
    });
    chart.appendChild(stackBar);

    // Legend
    LANGS.forEach(l => {
      const row = document.createElement('div');
      row.className = 'flex items-center justify-between text-xs';
      row.innerHTML = `
        <div class="flex items-center gap-2">
          <span style="width:10px;height:10px;border-radius:50%;background:${l.color};display:inline-block;box-shadow:0 0 4px ${l.color}"></span>
          <span class="text-gray-300">${l.name}</span>
        </div>
        <span style="color:${l.color}">${l.pct}%</span>
      `;
      chart.appendChild(row);
    });
  }
  buildLangs();

  // ─── RANDOM CONTRIB CELL FLICKER ─────────────────────────────────────────────
  setInterval(() => {
    const cells = document.querySelectorAll('.contrib-cell');
    const cell  = cells[Math.floor(Math.random() * cells.length)];
    const prev  = cell.style.background;
    cell.style.background = '#00f5ff';
    cell.style.boxShadow  = '0 0 8px #00f5ff';
    setTimeout(() => {
      cell.style.background = prev;
      cell.style.boxShadow  = 'none';
    }, 400);
  }, 600);
  </script>
</body>
</html>
